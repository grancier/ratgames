{
  "name": "mazegame-web-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal browser shell that runs mazegame (ratgames) via WebAssembly.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:release": "node build.mjs --release",
    "typecheck": "tsc --noEmit",
    "serve": "node serve.mjs",
    "dev": "node build.mjs && node serve.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
